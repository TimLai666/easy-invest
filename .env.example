APP_ENV=development
APP_SECRET=change-me-at-least-32-bytes
HTTP_ADDR=:8080
DATABASE_URL=postgres://easy_invest:easy_invest@postgres:5432/easy_invest?sslmode=disable
ENABLE_REGISTRATION=true
TWSE_DAILY_ALL_URL=https://openapi.twse.com.tw/v1/exchangeReport/STOCK_DAY_ALL
TWSE_STOCK_DAY_URL=https://www.twse.com.tw/exchangeReport/STOCK_DAY
TWSE_CORP_ACTIONS_URL=https://openapi.twse.com.tw/v1/exchangeReport/TWT48U_ALL
TWSE_HOLIDAY_QUERY_URL=https://www.twse.com.tw/rwd/zh/holidaySchedule/holidaySchedule
TPEX_DAILY_ALL_URL=https://www.tpex.org.tw/openapi/v1/tpex_mainboard_daily_close_quotes
TPEX_STOCK_DAY_URL=https://www.tpex.org.tw/www/zh-tw/afterTrading/tradingStock
MARKET_IMPORT_ON_START=true

# 資料庫備份（worker）：pg_dump custom 格式，每日輪替保留 BACKUP_KEEP 份
BACKUP_DIR=/backups
BACKUP_KEEP=14
BACKUP_CRON=0 2 * * *
BACKUP_ON_START=false
